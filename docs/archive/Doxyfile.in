# docs/Doxyfile.in — TEMPLATE for the generated C++ API reference (kimiactions C5).
#
# This is a Doxygen config TEMPLATE: cmake/Docs.cmake runs configure_file(... @ONLY)
# to substitute the at-delimited CMake tokens below into <build>/docs/Doxyfile, then
# the `docs` custom target invokes Doxygen::doxygen on the result.
#
# DOC-ONLY / NO-CUDA: Doxygen parses the public headers as TEXT — no compiler, no CUDA
# toolkit, no device link — so the `docs` target is the ONE target that builds on the
# local non-Blackwell dev box (the key property C5 exploits; iterate docs locally).
#
# SINGLE-SOURCE: PROJECT_NUMBER is substituted from @PROJECT_VERSION@ (the top-level
# project(VERSION ...) — the same single source the wheel version and the CLI/extract
# STEPPE_VERSION compile-definition derive from), so the docs version never drifts.

PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "@PROJECT_DESCRIPTION@"
OUTPUT_DIRECTORY       = "@STEPPE_DOXYGEN_OUTPUT_DIR@"

# The PUBLIC, CUDA-free header surface (architecture.md §4 — include/steppe is the
# stability-promised C++ surface). STEPPE_DOXYGEN_INPUT is set in cmake/Docs.cmake.
INPUT                  = "@STEPPE_DOXYGEN_INPUT@"
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h

# include/steppe/*.hpp are already doxygen-style commented (`///` / `///<`); EXTRACT_ALL
# still emits a page for every public type even where a member is undocumented.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
SORT_MEMBER_DOCS       = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# Quiet, and do not fail/spam on undocumented members (EXTRACT_ALL covers them).
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
HAVE_DOT               = NO
