{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "120",
        "STEPPE_HAVE_EMU_TUNING": "ON"
      }
    },
    {
      "name": "dev",
      "displayName": "Dev (RelWithDebInfo, sm_120, tests on)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "STEPPE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-asan",
      "displayName": "Dev + ASan/UBSan (host C++ TUs only; .cu excluded)",
      "inherits": "dev",
      "cacheVariables": {
        "STEPPE_SANITIZER": "asan;ubsan"
      }
    },
    {
      "name": "dev-compute",
      "displayName": "Dev + compute-sanitizer lane marker (no codegen flags; wrap ctest with compute-sanitizer)",
      "inherits": "dev",
      "cacheVariables": {
        "STEPPE_SANITIZER": "compute"
      }
    },
    {
      "name": "release",
      "displayName": "Release (full ship arch list, tests off)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "STEPPE_NVTX": "OFF",
        "STEPPE_BUILD_TESTS": "OFF",
        "CMAKE_CUDA_ARCHITECTURES": "75-real;80-real;86-real;89-real;90-real;100-real;120-real;120-virtual"
      }
    },
    {
      "name": "ci",
      "displayName": "CI (release config, tests on)",
      "inherits": "release",
      "cacheVariables": {
        "STEPPE_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev",         "configurePreset": "dev" },
    { "name": "dev-asan",    "configurePreset": "dev-asan" },
    { "name": "dev-compute", "configurePreset": "dev-compute" },
    { "name": "release",     "configurePreset": "release" },
    { "name": "ci",          "configurePreset": "ci" }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true },
      "execution": { "stopOnFailure": false }
    },
    {
      "name": "dev-asan",
      "configurePreset": "dev-asan",
      "output": { "outputOnFailure": true },
      "execution": { "stopOnFailure": false }
    },
    {
      "name": "dev-compute",
      "configurePreset": "dev-compute",
      "output": { "outputOnFailure": true },
      "execution": { "stopOnFailure": false }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": { "outputOnFailure": true },
      "execution": { "stopOnFailure": false }
    }
  ]
}
