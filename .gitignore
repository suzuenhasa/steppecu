# ── Build & CMake ─────────────────────────────────────────────────
build/
cmake-build-*/
/out/
/dist/
CMakeUserPresets.json
# in-source configure leftovers (shouldn't appear with the out-of-tree presets)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
Testing/

# ── Compiled artifacts ────────────────────────────────────────────
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.cubin
*.ptx
*.fatbin
# stray direct-nvcc spike binaries
test_f2_equivalence
test_f2_estimator
/experiments/f2_emu_spike/f2_emu_spike
/experiments/f2_emu_spike/f2_timing
/experiments/f2_emu_spike/f2_prec_acc
/experiments/**/*.f64
/experiments/**/*.bin

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.whl
.venv/
venv/

# ── Large data: real AADR genotypes, regenerated by aadr/ scripts, never committed.
# Scoped to aadr/ so the tiny committed fixtures under tests/fixtures/ stay tracked.
*.zip
/aadr/*.geno
/aadr/*.snp
/aadr/*.ind
/aadr/*.anno
/aadr/*.f64
/aadr/[QVN].bin

# ── docs/: publish only these subdirs; everything else under docs/ is local-only ──
docs/*
!docs/reference/
!docs/examples/
!docs/userguide/
!docs/assets/
docs/examples/notebooks/*.html
docs/commentdump/*
!docs/commentdump/extract_comments.py

# bench harness generated output (regenerate with: cmake --build --target bench)
tests/bench/out/
tests/bench/__pycache__/
