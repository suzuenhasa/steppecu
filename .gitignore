# --- Build trees -------------------------------------------------------------
/build/
build/
/out/
cmake-build-*/
CMakeUserPresets.json

# CMake in-tree artifacts (should never appear with the out-of-tree presets,
# but guard against an accidental in-source configure).
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
Testing/

# --- Standalone / spike build outputs (stray direct-nvcc binaries) ---
/test_f2_equivalence
/test_f2_estimator
test_f2_equivalence
test_f2_estimator
/experiments/f2_emu_spike/f2_emu_spike
/experiments/f2_emu_spike/f2_timing
/experiments/f2_emu_spike/f2_prec_acc

# --- Compiled objects / libs / device artifacts ------------------------------
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.cubin
*.ptx
*.fatbin

# --- Python (bindings, build scripts, aadr matrix builders) ------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.whl
.venv/
venv/

# --- Large data / downloads (real AADR genotype data — NOT source) -----------
# Precision/throughput claims are benchmarked on this real data; it is large and
# regenerated by the aadr/ download scripts, never committed. Scoped to the data
# dirs so tiny committed test fixtures under tests/fixtures/ are NOT ignored.
*.zip
/aadr/*.geno
/aadr/*.snp
/aadr/*.ind
/aadr/*.anno
/aadr/*.f64
/aadr/Q.bin
/aadr/V.bin
/aadr/N.bin
/experiments/**/*.f64
/experiments/**/*.bin

# --- Local agent/workflow scripts (NOT source; carry ephemeral box IPs/paths) ---
# The workflow orchestration scripts are a local dev convenience, not part of the
# shipped product, and embed ephemeral vast.ai box IPs / SSH-key paths. Untracked
# (kept on disk) to avoid leaking those into a public repo.
agentscripts/

# --- Editor / OS -------------------------------------------------------------
.vscode/
.idea/
.cache/
*.swp
*~
.DS_Store
handoff-*.md

# --- Claude Code local project config (not shipped; kept on disk, never wiped as untracked) ---
.claude/

# --- Comment dump: generated per-file comment extracts (regenerable; not shipped). Keep the
# extractor script tracked; ignore its large, regenerable output tree so `git clean -fd` skips it.
docs/commentdump/*
!docs/commentdump/extract_comments.py
